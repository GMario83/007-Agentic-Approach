    style ING3 fill:#1ABC9C,color:#fff
    style ING4 fill:#1ABC9C,color:#fff
    style ING5 fill:#1ABC9C,color:#fff
    style BATCH_E fill:#E74C3C,color:#fff
    style PAR_BCD fill:#F39C12,color:#fff
    style PAR_BC fill:#F39C12,color:#fff
    style PAR_BD fill:#F39C12,color:#fff
    style PAR_CD fill:#F39C12,color:#fff
